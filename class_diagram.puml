Services.NeuralNetworkPredictor ..|> Services.IAIService
Services.RecommendationService ..|> Services.IRecommendationService
Services.UserService ..|> Services.IUserService
Services.DeviceService ..|> Services.IDeviceService
Services.ReportService ..|> Services.IReportService

Services.AuthService o-- DataAccessLayer.IUserRepository
Services.CalculationService o-- DataAccessLayer.IDeviceRepository
Services.CalculationService o-- DataAccessLayer.ICalculationRepository
Services.NeuralNetworkPredictor o-- DataAccessLayer.IPredictionRepository
Services.RecommendationService o-- DataAccessLayer.IDeviceRepository
Services.UserService o-- DataAccessLayer.IUserRepository
Services.DeviceService o-- DataAccessLayer.IDeviceRepository
Services.ReportService o-- DataAccessLayer.ICalculationRepository 
