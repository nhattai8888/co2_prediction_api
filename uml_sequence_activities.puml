'=========================================
'        Activity Diagram - User Login
'=========================================
@startuml Activity_Diagram_User_Login
title Activity Diagram - User Login

start
:Hiển thị màn hình Login;
:Người dùng nhập Username & Password;
:Người dùng nhấn nút Login;
:Gửi thông tin đăng nhập đến Backend;
if (Backend xác thực thành công?) then (yes)
  :Backend tạo và trả về Access Token;
  :Frontend lưu Token;
  :Chuyển hướng đến trang chính (Dashboard/Home);
  :Hiển thị giao diện đã đăng nhập;
else (no)
  :Backend trả về lỗi (401 Unauthorized);
  :Frontend hiển thị thông báo lỗi đăng nhập;
  :Giữ nguyên ở màn hình Login;
endif
stop
@enduml
' End of Activity Diagram - User Login


newpage
'==================================================
'        Activity Diagram - Client CO2 Calculation
'==================================================
@startuml Activity_Diagram_Client_CO2_Calculation
title Activity Diagram - Client CO2 Calculation

start
:Client truy cập trang Tính toán CO2;
:Hệ thống tải danh sách thiết bị;
:Hiển thị Form cho Client;
:Client chọn Thiết bị;
:Client nhập Số giờ sử dụng;
:Client nhấn nút "Tính toán";
:Frontend gửi yêu cầu (thiết bị, giờ) đến Backend;
partition Backend {
  :Xác thực Client;
  if (Xác thực thành công?) then (yes)
    :Tính toán CO2 (giờ, tháng);
    :Lưu kết quả tính toán;
    :Gọi AI để dự đoán CO2;
    :Lưu kết quả dự đoán;
    :Tạo đề xuất & so sánh;
    :Lấy thông tin Chính sách xanh;
    :Tổng hợp kết quả trả về;
  else (no)
    :Trả lỗi (e.g., 401);
  endif
}
if (Nhận phản hồi thành công từ Backend?) then (yes)
  :Frontend hiển thị Kết quả tính toán;
  :Hiển thị Dự đoán AI;
  :Hiển thị Biểu đồ so sánh;
  :Hiển thị Đề xuất;
  :Hiển thị Chính sách xanh;
else (no)
  :Frontend hiển thị thông báo lỗi;
endif
stop
@enduml
' End of Activity Diagram - Client CO2 Calculation


newpage
'=================================================
'        Activity Diagram - Backend Processing & AI
'=================================================
@startuml Activity_Diagram_Backend_Processing_AI
title Activity Diagram - Backend Processing & AI

start
:Nhận yêu cầu POST /calculate từ Client;
:Gọi AuthService để xác thực Token;
if (Token hợp lệ và User tồn tại?) then (yes)
  :Lấy thông tin User;
  :Lấy thông tin Device từ request;
  :Gọi CalculationService.calculate_co2;
  partition CalculationService {
    :Lấy chi tiết Device (power, factor) từ DB;
    :Thực hiện tính toán CO2 giờ/tháng;
    :Lưu CalculationResult vào DB;
    :Trả về CalculationResult;
  }
  :Lấy features từ dữ liệu đầu vào & kết quả tính toán;
  :Gọi AIService.predict;
  partition AIService {
    :Load model & scaler;
    :Tiền xử lý features;
    :Thực hiện dự đoán;
    :Lưu PredictionResult vào DB;
    :Trả về PredictionResult (dự đoán, MAE, RMSE);
  }
  :Gọi RecommendationService.generate_recommendations;
   partition RecommendationService {
    :Phân tích kết quả tính toán & dự đoán;
    :Truy vấn DB lấy các thiết bị tương tự để so sánh;
    :Gọi nguồn dữ liệu ngoài lấy chính sách xanh;
    :Tổng hợp danh sách đề xuất;
    :Trả về List<Recommendation>;
  }
  :Xây dựng response tổng hợp (calculation, prediction, recommendations);
  :Trả response 200 OK cho Client;
else (no)
  :Trả response lỗi 401 Unauthorized;
endif
stop
@enduml
' End of Activity Diagram - Backend Processing & AI


newpage
'==================================================
'        Activity Diagram - Admin Edits User
'==================================================
@startuml Activity_Diagram_Admin_Edits_User
title Activity Diagram - Admin Edits User

start
:Admin đăng nhập thành công;
:Admin truy cập trang Quản lý Người dùng;
:Hệ thống hiển thị danh sách người dùng;
:Admin chọn một người dùng và nhấn "Chỉnh sửa";
:Hệ thống hiển thị Form với thông tin người dùng hiện tại;
:Admin thay đổi thông tin trong Form;
:Admin nhấn nút "Lưu";
:Frontend gửi yêu cầu PUT /admin/users/{id} với dữ liệu mới;
partition Backend {
 :Xác thực Admin (qua Token);
 if (Admin hợp lệ?) then (yes)
   :Validate dữ liệu đầu vào;
   if (Dữ liệu hợp lệ?) then (yes)
     :Gọi UserService.update_user;
      partition UserService {
       :Cập nhật thông tin User trong DB;
       :Trả về thông tin User đã cập nhật;
      }
     :Trả response 200 OK (Success);
   else (no)
     :Trả response lỗi 400 Bad Request (Validation Error);
   endif
 else (no)
   :Trả response lỗi 403 Forbidden;
 endif
}
if (Nhận phản hồi thành công?) then (yes)
  :Frontend cập nhật lại danh sách Users;
  :Hiển thị thông báo thành công;
  :Quay lại màn hình danh sách Users;
else (no)
  :Frontend hiển thị thông báo lỗi (từ Backend);
  :Giữ nguyên Form chỉnh sửa;
endif
stop
@enduml
' End of Activity Diagram - Admin Edits User